# Получите токен у @BotFather. Никому его не передавайте.
BOT_TOKEN=1234567890:PASTE_YOUR_TOKEN_HERE

# Часовой пояс мастерской. Для UTC+4 используйте Europe/Samara
TIMEZONE=Europe/Samara

# ID разрешённой рабочей Telegram-группы.
# Узнать: добавьте бота в группу и отправьте /chatid от имени администратора.
WORK_CHAT_ID=

# Telegram ID владельца/администраторов через запятую.
# Эти пользователи всегда получают полный доступ и не блокируются через меню.
# Свой ID можно узнать командой /id даже до получения доступа.
ADMIN_IDS=123456789

# Необязательно: сотрудники, которым нужно сразу выдать доступ при первом запуске.
# Через запятую, например: 111111111,222222222
# Позже сотрудников удобнее добавлять через меню «Сотрудники» или /adduser ID.
ALLOWED_IDS=

# Локальная база данных
DB_PATH=data/factory_bot.sqlite3

# Папка локальных копий фотографий портфолио
PORTFOLIO_DIR=data/portfolio
